# Build output that is regenerated (the committed bundle lives in data/bundle/)
/tmp-bundle/

# Never commit source workbooks dropped locally that are not part of the audit trail.
# NOTE: data/raw/ IS committed on purpose (audit trail). Local scratch xlsx go here:
*.local.xlsx
